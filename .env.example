# Configuración del Sistema ALMACEN 1.0

# --- BACKEND (FastAPI) ---
# URL de la base de datos (PostgreSQL)
# Local: postgresql://postgres:postgres@localhost:5432/almacen_db
# Producción: Proporcionada por Railway o Render
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# Clave secreta para JWT (Cámbiala por algo seguro en producción)
SECRET_KEY=su-clave-secreta-aqui-muy-segura

# --- FRONTEND (Next.js) ---
# URL del backend
# Local: http://localhost:8000
# Producción: La URL donde alojes el backend
NEXT_PUBLIC_API_URL=http://localhost:8000
